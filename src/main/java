public class TicTacToeGame {
    // Current board state (from UC1)
    private char[][] board = {
        {'-', '-', '-'},
        {'-', '-', '-'},
        {'-', '-', '-'}
    };

    /**
     * Updates the board state with the given symbol (Key Concept: State Update)
     * @param row Validated row index
     * @param col Validated column index
     * @param symbol 'X' or 'O' based on the player
     */
    public void placeMove(int row, int col, char symbol) {
        // Key Requirement: Update board correctly
        // Key Concept: Array Indexing
        board[row][col] = symbol;

        System.out.println("Placed '" + symbol + "' at (" + row + ", " + col + ")");
    }

    // Helper method to see the updated board (Reusable Method)
    public void displayBoard() {
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                System.out.print(board[i][j] + " ");
            }
            System.out.println();
        }
    }

    public static void main(String[] args) {
        TicTacToeGame game = new TicTacToeGame();

        // Flow: Valid move -> symbol placed -> board updated
        int row = 1; // Result from UC4 mapping
        int col = 1; // Result from UC4 mapping
        char playerSymbol = 'X'; // Result from UC2 toss

        game.placeMove(row, col, playerSymbol);
        game.displayBoard();
    }
}