import java.util.Random;

public class TicTacToeGame {
    private char[][] board = {
        {'-', '-', '-'},
        {'-', '-', '-'},
        {'-', '-', '-'}
    };

    // UC7: Computer Player Logic
    public void computerMakesMove(char computerSymbol) {
        Random random = new Random();
        boolean movePlaced = false;

        System.out.println("Computer's turn...");

        // Key Concept: Loop Until Valid
        while (!movePlaced) {
            // Key Requirement: Generate slot 1-9
            int slot = random.nextInt(9) + 1;

            // Key Concept: Logic Reuse (Reusing UC4 conversion)
            int row = (slot - 1) / 3;
            int col = (slot - 1) % 3;

            // Key Requirement: Ensure move validity (Reusing UC5 logic)
            if (board[row][col] == '-') {
                board[row][col] = computerSymbol;
                System.out.println("Computer placed " + computerSymbol + " in slot " + slot);
                movePlaced = true; // Exit loop
            }
            // If the cell wasn't '-', the loop runs again to find a new random slot
        }
    }

    // Helper to see the board
    public void displayBoard() {
        for (char[] row : board) {
            for (char cell : row) {
                System.out.print(cell + " ");
            }
            System.out.println();
        }
    }

    public static void main(String[] args) {
        TicTacToeGame game = new TicTacToeGame();

        // Simulating the flow
        game.computerMakesMove('O');
        game.displayBoard();
    }
}