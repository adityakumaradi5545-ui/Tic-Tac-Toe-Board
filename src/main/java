public class TicTacToeGame {
    // Standard empty cell placeholder from UC1
    private char[][] board = new char[3][3];

    /**
     * Checks if the game is a draw.
     * (Key Concept: Boolean Flags & Loop Traversal)
     * @return true if the board is full and there are no empty cells.
     */
    public boolean isDraw() {
        // We use a boolean flag to track if we find an empty cell
        boolean foundEmptyCell = false;

        // 1. Loop Traversal: Check every cell in the 2D array
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                // If even one cell contains the placeholder '-', the board isn't full
                if (board[i][j] == '-') {
                    foundEmptyCell = true;
                    break; // Optimization: stop looking if we find one empty spot
                }
            }
            if (foundEmptyCell) break;
        }

        // 2. Draw Declared: If no empty cell was found, it's a draw
        // (Assuming you call this ONLY after checking for a winner first)
        return !foundEmptyCell;
    }
}