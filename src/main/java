public class TicTacToeGame {

    // Utility Method for conversion (Key Concept: Utility Methods)
    public void convertSlotToIndices(int slot) {
        // Step 1: Adjust for Zero-based Indexing (Key Concept: Zero-based Indexing)
        // User enters 1-9, but arrays use 0-8
        int adjustedSlot = slot - 1;

        // Step 2: Use Division and Modulo (Key Concept: Division and Modulo)
        // Row = index / grid_size
        // Column = index % grid_size
        int row = adjustedSlot / 3;
        int col = adjustedSlot % 3;

        // Output results (Key Requirement: Convert to valid indices)
        System.out.println("Slot " + slot + " maps to: Row " + row + ", Column " + col);
    }

    public static void main(String[] args) {
        TicTacToeGame game = new TicTacToeGame();

        // Testing the mapping for a few slots
        game.convertSlotToIndices(1); // Should be (0,0)
        game.convertSlotToIndices(5); // Should be (1,1)
        game.convertSlotToIndices(9); // Should be (2,2)
    }
}