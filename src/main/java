vpublic class TicTacToeGame {
     private boolean gameRunning = true; // Key Concept: Game State Flag
     private String currentPlayer = "User"; // Starting player

     public void playGame() {
         // Key Concept: While Loop (continues until win or draw is detected)
         while (gameRunning) {
             System.out.println("\n--- " + currentPlayer + "'s Turn ---");

             // 1. Player Move (UC3/UC7 logic would be called here)
             processMove();

             // 2. Check Win/Draw (Key Requirement: Stop loop on win or draw)
             if (checkForWinOrDraw()) {
                 gameRunning = false; // Updates flag to stop the loop
                 System.out.println("Game Over!");
             } else {
                 // 3. Switch Turn (Key Requirement: Alternate turns)
                 switchTurn();
             }
         }
     }

     private void processMove() {
         // Logic to accept input and place mark on board
         System.out.println(currentPlayer + " made a move.");
     }

     private void switchTurn() {
         // Key Concept: Turn Switching
         currentPlayer = (currentPlayer.equals("User")) ? "Computer" : "User";
     }

     private boolean checkForWinOrDraw() {
         // Placeholder for win/draw detection logic
         // Return true if game should end, false to continue
         return false;
     }

     public static void main(String[] args) {
         TicTacToeGame game = new TicTacToeGame();
         game.playGame();
     }
 }