public class TicTacToeGame {
    // Assuming the board from UC1
    private char[][] board = {
        {'-', '-', '-'},
        {'-', '-', '-'},
        {'-', '-', '-'}
    };

    /**
     * Validates if the move is legal (Key Concept: Defensive Programming)
     * @param row The row index (0-2)
     * @param col The column index (0-2)
     * @return true if move is valid, false otherwise
     */
    public boolean validateMove(int row, int col) {
        // 1. Boundary Checking (Key Requirement: Row and column must be 0-2)
        if (row < 0 || row > 2 || col < 0 || col > 2) {
            System.out.println("Invalid move: Out of bounds!");
            return false;
        }

        // 2. Cell Occupancy Check (Key Requirement: Cell must be empty)
        // Assuming '-' represents an empty cell as per UC1
        if (board[row][col] != '-') {
            System.out.println("Invalid move: Cell already occupied!");
            return false;
        }

        // 3. Validation Performed -> Move Accepted
        System.out.println("Move is valid.");
        return true;
    }

    public static void main(String[] args) {
        TicTacToeGame game = new TicTacToeGame();

        // Testing Flow of Execution:
        // Case 1: Valid move
        game.validateMove(0, 0);

        // Case 2: Out of bounds
        game.validateMove(3, 1);

        // Case 3: Cell already occupied (Simulating a move)
        game.board[1][1] = 'X';
        game.validateMove(1, 1);
    }
}