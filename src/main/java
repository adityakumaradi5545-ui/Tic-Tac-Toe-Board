import java.util.Random;

public class TicTacToeGame {
    // Game State Variables (Theoretical Concept #3)
    private char player1Symbol;
    private char player2Symbol;
    private String currentPlayer;

    public void performToss() {
        // 1. Random Number Generation (Theoretical Concept #1)
        Random random = new Random();
        int tossResult = random.nextInt(2); // Generates 0 or 1

        // 2. Conditional Logic for Assignment (Theoretical Concept #2)
        if (tossResult == 0) {
            System.out.println("Toss Result: Player 1 starts first!");
            currentPlayer = "Player 1";
            player1Symbol = 'X';
            player2Symbol = 'O';
        } else {
            System.out.println("Toss Result: Player 2 starts first!");
            currentPlayer = "Player 2";
            player2Symbol = 'X';
            player1Symbol = 'O';
        }

        // Displaying assigned roles
        System.out.println("Player 1 Symbol: " + player1Symbol);
        System.out.println("Player 2 Symbol: " + player2Symbol);
    }

    public static void main(String[] args) {
        TicTacToeGame game = new TicTacToeGame();
        game.performToss();
    }
}